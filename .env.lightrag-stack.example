### LightRAG Docker stack environment.
### Copy this file to `.env.lightrag-stack` for local deployment.
### Keep real API keys in `.env` or in your deployment secret manager.

###########################
### Published ports
###########################
STACK_LIGHTRAG_BIND_HOST=0.0.0.0
STACK_LIGHTRAG_PORT=9621
STACK_DOTENV_FILE=./.env
STACK_POSTGRES_BIND_HOST=127.0.0.1
STACK_POSTGRES_PORT=15432
STACK_QDRANT_BIND_HOST=127.0.0.1
STACK_QDRANT_PORT=6333
STACK_NEO4J_HTTP_BIND_HOST=127.0.0.1
STACK_NEO4J_HTTP_PORT=7474
STACK_NEO4J_BOLT_BIND_HOST=127.0.0.1
STACK_NEO4J_BOLT_PORT=7687
STACK_MINERU_BIND_HOST=127.0.0.1
STACK_MINERU_PORT=8000
STACK_MINERU_POLL_INTERVAL_SECONDS=2
STACK_MINERU_MAX_POLLS=900
STACK_MINERU_HTTP_TIMEOUT_SECONDS=1800

###########################
### Images
###########################
### Local image tag built from this checkout. Rebuild after backend/frontend
### source changes with:
### docker compose --env-file .env.lightrag-stack -f docker-compose.lightrag-stack.yml build lightrag
STACK_LIGHTRAG_IMAGE=lightrag-stack:local
STACK_POSTGRES_IMAGE=gzdaniel/postgres-for-rag:16.6
STACK_QDRANT_IMAGE=qdrant/qdrant:latest
STACK_NEO4J_IMAGE=neo4j:5-community

### MinerU is profile-gated because LightRAG does not vendor the MinerU image.
### Build `mineru:latest` from `.docker/mineru/Dockerfile` before starting the
### profile. The local development image uses the vLLM base image, installs
### `mineru[core]`, downloads all MinerU models from ModelScope, and exposes
### /health, /tasks and /tasks/{id}/result through `mineru-api`.
STACK_MINERU_IMAGE=mineru:latest
STACK_MINERU_MODEL_SOURCE=local

###########################
### PostgreSQL
###########################
STACK_POSTGRES_USER=postgres
STACK_POSTGRES_PASSWORD=123456
STACK_POSTGRES_DATABASE=rag
STACK_POSTGRES_MAX_CONNECTIONS=25

###########################
### Neo4j
###########################
STACK_NEO4J_USERNAME=neo4j
STACK_NEO4J_PASSWORD=123456
STACK_NEO4J_DATABASE=neo4j
STACK_NEO4J_MIN_PASSWORD_LENGTH=6
STACK_NEO4J_HEAP_INITIAL=512m
STACK_NEO4J_HEAP_MAX=2G
STACK_NEO4J_PAGECACHE=1G

###########################
### MinerU local parser
###########################
### If using the bundled `mineru-api` service, keep this value.
### If MinerU runs elsewhere, point this to that HTTP endpoint.
STACK_MINERU_LOCAL_ENDPOINT=http://mineru-api:8000
STACK_MINERU_LOCAL_BACKEND=hybrid-auto-engine
STACK_MINERU_LOCAL_PARSE_METHOD=auto
STACK_MINERU_LOCAL_IMAGE_ANALYSIS=true

###########################
### LightRAG file parser
###########################
### Cost-safe default:
### - DOCX: native parser, table/equation processing, paragraph chunking
### - PDF: MinerU parser, image/table/equation options available
### - images: MinerU parser
### - others: legacy parser with recursive chunking
STACK_LIGHTRAG_PARSER=docx:native-teP,pdf:mineru-iteP,png:mineru-iP,jpg:mineru-iP,jpeg:mineru-iP,*:legacy-R

### Set true only after configuring a VLM-capable model in `.env`.
### When false, LightRAG will not call the VLM for image/table/equation analysis.
STACK_VLM_PROCESS_ENABLE=true

###########################
### LLM / Embedding notes
###########################
### This file intentionally does not contain real API keys.
### Keep existing values such as LLM_BINDING, LLM_BINDING_HOST,
### LLM_BINDING_API_KEY, EMBEDDING_* and role-specific EXTRACT/QUERY/VLM
### variables in `.env`, or inject them through your deployment platform.
###
### If your model service runs on the host and LightRAG runs in Docker, do not
### use localhost inside the container. Use host.docker.internal instead, e.g.:
### LLM_BINDING_HOST=http://host.docker.internal:11434
